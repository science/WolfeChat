event: response.reasoning_summary_text.done
data: {"type":"response.reasoning_summary_text.done","item_id":"rs_033a97a9e38891b10169e3dc2ca0188194aef0f79e4aa9e4fd","output_index":0,"sequence_number":764,"summary_index":5,"text":"**Creating a Kyoto itinerary with cultural experiences**\n\nI’m planning an itinerary that balances cultural workshops, like a tea ceremony or calligraphy, while avoiding crowds. \n\nOn Day 1, I’ll start with Arashiyama's bamboo grove early, then visit Tenryu-ji and Otagi Nenbutsu-ji. Day 2 will focus on Fushimi Inari and the sake district, followed by Toji. For Day 3, I’ll suggest Shimogamo and Kamigamo Shrines, a cultural workshop, then explore Kurama for hiking. I’ll include budget tips and transport details while emphasizing early starts and lesser-known places to minimize crowds."}

event: response.reasoning_summary_part.done
data: {"type":"response.reasoning_summary_part.done","item_id":"rs_033a97a9e38891b10169e3dc2ca0188194aef0f79e4aa9e4fd","output_index":0,"part":{"type":"summary_text","text":"**Creating a Kyoto itinerary with cultural experiences**\n\nI’m planning an itinerary that balances cultural workshops, like a tea ceremony or calligraphy, while avoiding crowds. \n\nOn Day 1, I’ll start with Arashiyama's bamboo grove early, then visit Tenryu-ji and Otagi Nenbutsu-ji. Day 2 will focus on Fushimi Inari and the sake district, followed by Toji. For Day 3, I’ll suggest Shimogamo and Kamigamo Shrines, a cultural workshop, then explore Kurama for hiking. I’ll include budget tips and transport details while emphasizing early starts and lesser-known places to minimize crowds."},"sequence_number":765,"summary_index":5}

